# Environment Variables Template
# Copy this file to .env.local and fill in your values

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/azure-blog

# Site Configuration (for SEO and metadata)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# NextAuth Configuration
NEXTAUTH_SECRET=generate_with_openssl_rand_base64_32
NEXTAUTH_URL=http://localhost:3000

# Shopify Storefront API
# Instructions: https://shopify.dev/docs/api/storefront
NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your_storefront_access_token_here

# Giscus Comments (Optional)
NEXT_PUBLIC_GITHUB_OWNER=your-github-username
NEXT_PUBLIC_GITHUB_REPO=your-repo-name
NEXT_PUBLIC_GISCUS_REPO_ID=your_giscus_repo_id
NEXT_PUBLIC_GISCUS_CATEGORY_ID=your_giscus_category_id
